{
	"name": "iobroker.f1",
	"version": "0.1.0",
	"description": "Formula 1 live data integration for ioBroker - race information, standings, and live session tracking",
	"author": {
		"name": "Martin Rauscher(bloop16)",
		"email": "bloop16@hotmail.com"
	},
	"contributors": [],
	"homepage": "https://github.com/bloop16/ioBroker.f1",
	"license": "MIT",
	"keywords": [
		"ioBroker",
		"Formula 1",
		"F1",
		"racing",
		"motorsport",
		"live data",
		"standings",
		"calendar"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/bloop16/ioBroker.f1.git"
	},
	"engines": {
		"node": ">= 20"
	},
	"dependencies": {
		"@iobroker/adapter-core": "^3.3.2",
		"axios": "^1.7.9"
	},
	"devDependencies": {
		"@alcalzone/release-script": "^5.1.1",
		"@alcalzone/release-script-plugin-iobroker": "^5.1.2",
		"@alcalzone/release-script-plugin-license": "^5.1.1",
		"@alcalzone/release-script-plugin-manual-review": "^5.1.1",
		"@iobroker/adapter-dev": "^1.5.0",
		"@iobroker/dev-server": "^0.8.0",
		"@iobroker/eslint-config": "^2.2.0",
		"@iobroker/testing": "^5.2.2",
		"@tsconfig/node20": "^20.1.9",
		"@types/axios": "^0.9.36",
		"@types/node": "^22.10.2",
		"@typescript-eslint/eslint-plugin": "^8.18.2",
		"@typescript-eslint/parser": "^8.18.2",
		"eslint": "^9.17.0",
		"eslint-config-prettier": "^10.0.1",
		"eslint-plugin-prettier": "^5.2.1",
		"prettier": "^3.4.2",
		"rimraf": "^6.0.1",
		"typescript": "~5.7.2"
	},
	"main": "build/main.js",
	"files": [
		"admin/",
		"build/",
		"io-package.json",
		"LICENSE"
	],
"scripts": {
    "test:js": "mocha --config test/mocharc.custom.json \"{!(node_modules|test)/**/*.test.js,*.test.js,test/**/test!(PackageFiles|Startup).js}\"",
    "test:package": "mocha test/package --exit",
    "test:unit": "mocha test/unit --exit",
    "test:integration": "mocha test/integration --exit",
    "test": "npm run test:js && npm run test:unit && npm run test:package",
    "check": "tsc --noEmit -p tsconfig.check.json",
    "lint": "eslint -c eslint.config.mjs",
    "build": "tsc -p tsconfig.build.json",
    "translate": "translate-adapter",
    "release": "release-script"
  }
}